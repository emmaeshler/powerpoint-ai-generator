# ============================================================
#  Emma's Awesome PPT Generator — Environment Variables
#  Copy this file to .env and fill in the values below.
#  .env is git-ignored and never committed.
# ============================================================

# ── Azure Foundry (required for AI generation) ───────────────
# The full endpoint URL for your Azure AI Foundry deployment.
# Format: https://<resource>.openai.azure.com/openai/deployments/<deployment>/messages?api-version=...
FOUNDRY_TARGET_URI=

# The model name as configured in your Azure AI Foundry deployment.
# e.g. claude-3-5-sonnet, claude-3-haiku
MODEL=

# ── Azure authentication (choose one method) ─────────────────
# METHOD A — Azure CLI (recommended for local dev):
#   Just run `az login` in your terminal. No env vars needed.

# METHOD B — Service principal (CI / shared machines):
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
